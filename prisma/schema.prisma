generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma_runtime"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String   @id @default(cuid())
  NamaLengkap String
  Email       String   @unique
  Password    String
  isActive    Boolean  @default(true)
  CreatedAt   DateTime @default(now())
  UpdatedAt   DateTime @updatedAt
  roleId      String
  masjidId    String?
  donasi      Donasi[]
  auditLogs   AuditLog[]
  updatedConfigs SystemConfig[] @relation("SystemConfigUpdatedBy")
  masjid      Masjid?  @relation(fields: [masjidId], references: [id])
  role        Role     @relation(fields: [roleId], references: [id])

  @@map("User")
}

model Role {
  id    String @id @default(cuid())
  Nama  String
  users User[]

  @@map("Role")
}

model Masjid {
  id                        String                      @id @default(cuid())
  Nama                      String
  Alamat                    String
  NomorTelepon              String
  isActive                  Boolean                     @default(true)
  TanggalBerdiri            DateTime?
  LuasTanah                 Float?
  Kapasitas_Jamaah          Int?
  Deskripsi                 String?
  Visi                      String?
  Misi                      String?
  FotoLuarMasjid            String[]                    @default([])
  FotoDalamMasjid           String[]                    @default([])
  SuratIzinMasjid           String?
  SuratPengantar            String?
  PenghargaanMasjid         String[]                    @default([])
  StatusKepemilikan         StatusKepemilikan?
  accounts                  Account[]
  donasi_masjid             Donasi_Masjid[]
  fasilitasMasjid           Fasilitas_Masjid[]
  jurnalTransactions        JurnalTransaction[]
  kegiatanMasjid            Kegiatan_Masjid[]
  laporanMasjid             LaporanKeuanganMasjid[]
  pengeluaran_donasi_masjid Pengeluaran_Donasi_Masjid[]
  users                     User[]

  @@map("Masjid")
}

model LaporanKeuanganMasjid {
  id         String               @id @default(cuid())
  masjidId   String
  jenis      JenisLaporanKeuangan
  fileUrl    String
  uploadedAt DateTime             @default(now())
  fileSizeKB Int
  masjid     Masjid               @relation(fields: [masjidId], references: [id])

  @@map("Laporan_Keuangan_Masjid")
}

model Fasilitas_Masjid {
  id       String           @id @default(cuid())
  Nama     String
  Kondisi  KondisiFasilitas
  masjidId String
  masjid   Masjid           @relation(fields: [masjidId], references: [id])

  @@map("Fasilitas_Masjid")
}

model Kegiatan_Masjid {
  id          String   @id @default(cuid())
  Nama        String
  Dokumentasi String[] @default([])
  masjidId    String
  masjid      Masjid   @relation(fields: [masjidId], references: [id])

  @@map("Kegiatan_Masjid")
}

model Kategori_Donasi {
  id                        String                      @id @default(cuid())
  Nama                      String
  isActive                  Boolean                     @default(true)
  donasi_masjid             Donasi_Masjid[]
  pengeluaran_donasi_masjid Pengeluaran_Donasi_Masjid[]

  @@map("Kategori_Donasi")
}

model Kategori_Pengeluaran {
  id                        String                      @id @default(cuid())
  Nama                      String
  isActive                  Boolean                     @default(true)
  pengeluaran_donasi_masjid Pengeluaran_Donasi_Masjid[]

  @@map("Kategori_Pengeluaran")
}

model Donasi {
  id               String        @id @default(cuid())
  Nama             String
  Keterangan       String?
  JumlahDonasi     Decimal       @db.Decimal(15, 2)
  StatusDonasi     StatusDonasi  @default(Pending)
  CreatedAt        DateTime      @default(now())
  id_donasi_masjid String
  id_user          String
  Email            String?
  NoTelepon        String?
  donasi_masjid    Donasi_Masjid @relation(fields: [id_donasi_masjid], references: [id])
  user             User          @relation(fields: [id_user], references: [id])

  @@map("Donasi")
}

model Donasi_Masjid {
  id                        String                      @id @default(cuid())
  Nama                      String
  Deskripsi                 String?
  TargetUangDonasi          Decimal                     @db.Decimal(15, 2)
  UangDonasiTerkumpul       Decimal                     @default(0) @db.Decimal(15, 2)
  UangPengeluaran           Decimal                     @default(0) @db.Decimal(15, 2)
  id_masjid                 String
  id_kategori_donasi        String
  FotoDonasi                String?
  CreatedAt                 DateTime                    @default(now())
  donasi                    Donasi[]
  kategori_donasi           Kategori_Donasi             @relation(fields: [id_kategori_donasi], references: [id])
  masjid                    Masjid                      @relation(fields: [id_masjid], references: [id])
  pengeluaran_donasi_masjid Pengeluaran_Donasi_Masjid[]

  @@map("Donasi_Masjid")
}

model Pengeluaran_Donasi_Masjid {
  id                      String               @id @default(cuid())
  TujuanPengeluaran       String
  DeskripsiPengeluaran    String?
  UangPengeluaran         Decimal              @db.Decimal(15, 2)
  CreatedAt               DateTime             @default(now())
  id_donasi_masjid        String
  id_kategori_pengeluaran String
  masjidId                String?
  kategori_DonasiId       String?
  FotoPengeluaran         String?
  donasi_masjid           Donasi_Masjid        @relation(fields: [id_donasi_masjid], references: [id])
  kategori_pengeluaran    Kategori_Pengeluaran @relation(fields: [id_kategori_pengeluaran], references: [id])
  Kategori_Donasi         Kategori_Donasi?     @relation(fields: [kategori_DonasiId], references: [id])
  Masjid                  Masjid?              @relation(fields: [masjidId], references: [id])

  @@map("Pengeluaran_Donasi_Masjid")
}

model Account {
  id            String              @id @default(cuid())
  code          String
  name          String
  parentId      String?
  type          AccountType
  isGroup       Boolean             @default(false)
  pathCode      String
  masjidId      String?
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  normalBalance NormalBalance
  category      AccountCategory?
  report        AccountReport?
  restriction   AccountRestriction?
  masjid        Masjid?             @relation(fields: [masjidId], references: [id])
  parent        Account?            @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      Account[]           @relation("AccountHierarchy")
  jurnalEntries JurnalEntry[]

  @@unique([code, masjidId])
  @@map("Account")
}

model JurnalTransaction {
  id         String        @id @default(cuid())
  masjidId   String
  tanggal    DateTime
  keterangan String
  referensi  String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  entries    JurnalEntry[]
  masjid     Masjid        @relation(fields: [masjidId], references: [id])

  @@map("JurnalTransaction")
}

model JurnalEntry {
  id             String            @id @default(cuid())
  transactionId  String
  akunId         String
  tipe           JurnalTipe
  jumlah         Decimal           @db.Decimal(15, 2)
  createdAt      DateTime          @default(now())
  hasRestriction Boolean           @default(false)
  keterangan     String?
  akun           Account           @relation(fields: [akunId], references: [id])
  transaction    JurnalTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("JurnalEntry")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  entityName String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("AuditLog")
}

model SystemConfig {
  id              String   @id @default(cuid())
  key             String   @unique
  value           Json
  description     String?  @db.Text
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  updatedByUser User? @relation("SystemConfigUpdatedBy", fields: [updatedByUserId], references: [id])

  @@index([updatedByUserId])
  @@map("SystemConfig")
}

enum StatusKepemilikan {
  MILIK_SENDIRI
  TANAH_WAKAF
  HIBAH
  SEWA
}

enum JenisLaporanKeuangan {
  POSISI_KEUANGAN
  PENGHASILAN_KOMP
  PERUBAHAN_ASET_NETO
  ARUS_KAS
  CATATAN
  KEUANGAN_BULANAN
  KEUANGAN_TAHUNAN
}

enum KondisiFasilitas {
  KURANG_BAIK
  CUKUP_BAIK
  BAIK
  BAIK_SEKALI
  SANGAT_BAIK
}

enum StatusDonasi {
  Pending
  Sukses
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum NormalBalance {
  DEBIT
  KREDIT
}

enum AccountRestriction {
  TANPA_PEMBATASAN
  DENGAN_PEMBATASAN
}

enum AccountReport {
  NERACA
  LAPORAN_PENGHASILAN_KOMPREHENSIF
}

enum AccountCategory {
  ASET_LANCAR
  ASET_TIDAK_LANCAR
  HUTANG_JANGKA_PENDEK
  HUTANG_JANGKA_PANJANG
  ASET_NETO
  PENDAPATAN
  BEBAN
  PENGHASILAN_KOMPREHENSIF_LAIN
}

enum JurnalTipe {
  DEBIT
  KREDIT
}
